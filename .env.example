# ZPS Ad Intelligence — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git!

# Sensor Tower API
SENSOR_TOWER_TOKEN=your_sensor_tower_api_token_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Note: Use service_role key (NOT anon key) for serverless functions
# The service_role key bypasses RLS — only use server-side

# Optional: Supabase anon key for client-side (read-only, with RLS)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Gemini API (for AI Vision auto-tagging)
GEMINI_API_KEY=your_gemini_api_key_here
